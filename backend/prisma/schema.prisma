generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Theme {
  id        String     @id @default(cuid())
  name      String     @unique
  order     Int        @default(0)
  subThemes SubTheme[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model SubTheme {
  id        String     @id @default(cuid())
  name      String
  order     Int        @default(0)
  themeId   String
  theme     Theme      @relation(fields: [themeId], references: [id], onDelete: Cascade)
  questions Question[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([themeId, name])
}

model Question {
  id            String       @id @default(cuid())
  text          String
  choiceA       String
  choiceB       String
  choiceC       String
  choiceD       String
  choiceE       String       @default("")
  correctAnswer String       // "A" pour une réponse, "A,B,C" pour plusieurs
  explanation   String       @default("")
  imageUrl      String?
  order         Int          @default(0)
  isActive      Boolean      @default(true)
  subThemeId    String
  subTheme      SubTheme     @relation(fields: [subThemeId], references: [id], onDelete: Cascade)
  userAnswers   UserAnswer[]
  favorites     Favorite[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  passwordHash    String
  passwordResetToken        String?
  passwordResetTokenExpires DateTime?
  fullName        String
  pseudo          String?      @unique
  gender          String?
  profession      String?
  wilaya          String?
  phone           String?
  role            Role         @default(FREE)
  subscriptionEnd DateTime?
  isActive        Boolean      @default(true)
  sessions        Session[]
  refreshTokens   RefreshToken[]
  attempts        Attempt[]
  userAnswers     UserAnswer[]
  payments        Payment[]
  favorites       Favorite[]
  dailyQuestionCount Int       @default(0)
  lastQuestionDate   DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, questionId])
}

enum Role {
  FREE
  PREMIUM
  ADMIN
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId    String
  deviceInfo  String
  ipAddress   String
  isActive    Boolean  @default(true)
  lastActive  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId, isActive])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId  String
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Attempt {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode        AttemptMode
  themeId     String?
  subThemeId  String?
  totalQ      Int
  correctQ    Int          @default(0)
  score       Float        @default(0)
  timeTaken   Int          @default(0)
  timeLimit   Int?
  isCompleted Boolean      @default(false)
  answers     UserAnswer[]
  startedAt   DateTime     @default(now())
  completedAt DateTime?
}

enum AttemptMode {
  PRACTICE
  EXAM
  REVIEW
}

model UserAnswer {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  attemptId    String
  attempt      Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  userAnswer   String       // "A" ou "A,B,C" pour réponses multiples
  isCorrect    Boolean
  answeredAt   DateTime  @default(now())

  @@unique([attemptId, questionId])
  @@index([userId, questionId])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactionCode String?       @unique
  amount          Float
  durationDays    Int           @default(30)
  paymentMethod   String        @default("MOBILE_MONEY")
  operator        String?
  planType        String?
  groupSize       Int?
  receiptUrl      String?
  status          PaymentStatus @default(PENDING)
  validatedBy     String?
  validatedAt     DateTime?
  rejectionReason String?
  groupInvites    GroupInvite[]
  createdAt       DateTime      @default(now())
}

enum PaymentStatus {
  PENDING
  VALIDATED
  REJECTED
}

model GroupInvite {
  id        String   @id @default(cuid())
  email     String
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  isActive  Boolean  @default(false)
  isUsed    Boolean  @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@unique([email, paymentId])
  @@index([email])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
